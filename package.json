{
  "name": "easy-dev-proxy",
  "version": "0.0.4",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "tsc && tsc -p tsconfig.test.json",
    "build:watch": "tsc --watch",
    "prebuild": "rm -rf dist",
    "start": "npm run build && node index.js",
    "start:plugin:off": "EP_PLUGIN_MODE=off npm start",
    "start:plugin:shadow": "EP_PLUGIN_MODE=shadow npm start",
    "start:plugin:on": "EP_PLUGIN_MODE=on npm start",
    "smoke:refactor": "node scripts/refactor-smoke.js",
    "drill:rollout": "node scripts/plugin-rollout-drill.js",
    "test": "mocha 'dist/**/*.spec.js' 'dist/**/index.js'",
    "test:refactor": "npm run build && node -c index.js && npm test",
    "prepublish": "npm run build && npm run test",
    "start:open": "npm run build && node index.js --open",
    "doctor": "node bin/doctor.js",
    "mcp": "node mcp-server.js",
    "build:web": "cd web && pnpm run build",
    "dev:web": "cd web && pnpm run dev",
    "postinstall": "cd web && pnpm install && pnpm run build"
  },
  "bin": {
    "ep": "bin/index"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "chalk": "^4.1.2",
    "chokidar": "^3.5.3",
    "debug": "^4.3.4",
    "esbuild": "^0.27.3",
    "inquirer": "^8.2.5",
    "node-easy-cert": "^1.3.3",
    "portfinder": "^1.0.32",
    "puppeteer-core": "^24.0.0",
    "ws": "^8.12.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^18.19.130",
    "@types/ws": "^8.5.4",
    "mocha": "^10.2.0",
    "nodemon": "^2.0.20",
    "typescript": "^5.9.3"
  }
}

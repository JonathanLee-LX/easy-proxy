# Mock功能语法高亮和验证性能配置
# 这些参数可以根据实际使用场景调整

# 最大高亮文件大小（字节）
# 默认: 2097152 (2MB)
# 建议: 对于低配置机器可以设置为 1048576 (1MB)，高性能机器可以设置为 5242880 (5MB) 或更高
VITE_MAX_HIGHLIGHT_SIZE=2097152

# 最大高亮行数
# 默认: 10000
# 建议: 对于复杂文件可以设置为 20000 或更高
VITE_MAX_HIGHLIGHT_LINES=10000

# JSON语法高亮最大匹配数
# 默认: 50000
# 适用于: 大型JSON响应，嵌套深度较高的数据结构
VITE_MAX_JSON_MATCHES=50000

# HTML语法高亮最大匹配数
# 默认: 30000
# 适用于: 大型HTML页面，复杂的DOM结构
VITE_MAX_HTML_MATCHES=30000

# JavaScript语法高亮最大匹配数
# 默认: 30000
# 适用于: 打包后的JS文件，大型脚本
VITE_MAX_JS_MATCHES=30000

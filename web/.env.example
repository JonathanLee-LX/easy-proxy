# AI代码修复配置示例
# 复制此文件为 .env.local 并填入您的配置

# AI服务提供商: openai 或 anthropic
VITE_AI_PROVIDER=openai

# API密钥
VITE_AI_API_KEY=your_api_key_here

# API基础URL (可选,使用默认值或自定义)
# OpenAI默认: https://api.openai.com/v1/chat/completions
# Anthropic默认: https://api.anthropic.com/v1/messages
# VITE_AI_BASE_URL=https://api.openai.com/v1/chat/completions

# 使用的模型 (可选,使用默认值或自定义)
# OpenAI推荐: gpt-4o-mini, gpt-4o, gpt-3.5-turbo
# Anthropic推荐: claude-3-5-sonnet-20241022, claude-3-opus-20240229
# VITE_AI_MODEL=gpt-4o-mini

# ===== OpenAI 配置示例 =====
# VITE_AI_PROVIDER=openai
# VITE_AI_API_KEY=sk-xxx...
# VITE_AI_BASE_URL=https://api.openai.com/v1/chat/completions
# VITE_AI_MODEL=gpt-4o-mini

# ===== Anthropic 配置示例 =====
# VITE_AI_PROVIDER=anthropic
# VITE_AI_API_KEY=sk-ant-xxx...
# VITE_AI_BASE_URL=https://api.anthropic.com/v1/messages
# VITE_AI_MODEL=claude-3-5-sonnet-20241022

# ===== 自定义代理/第三方服务示例 =====
# VITE_AI_PROVIDER=openai
# VITE_AI_API_KEY=your_key
# VITE_AI_BASE_URL=https://your-proxy.com/v1/chat/completions
# VITE_AI_MODEL=gpt-4o-mini
